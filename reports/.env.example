# Example (DO NOT COMMIT real secrets)

# ============================================
# SOURCE CONFIGURATION
# ============================================
# SOURCE can be: excel or sheets
SOURCE=excel
EXCEL_PATH=../diario operativo.xlsx
OUT_DIR=output
TIMEZONE=America/Santiago

# ============================================
# GOOGLE SHEETS (if SOURCE=sheets)
# ============================================
# GOOGLE_SHEETS_SPREADSHEET_ID=1ABC123xyz...
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# ============================================
# AI ANALYSIS (OpenAI)
# ============================================
# Enable AI analysis (on/off)
AI=off

# OpenAI API credentials
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# AI analysis language (es, en)
AI_LANG=es

# Number of weeks to analyze (0 = only generate weekly HTML without AI)
AI_WEEKS_BACK=0

# ============================================
# SUPABASE (para migrate_to_supabase.py y SOURCE=supabase)
# ============================================
# SOURCE=supabase  ← activar para leer reportes desde Supabase en vez de Sheets/Excel

# URL del proyecto Supabase
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Service role key (Full access, bypasea RLS — nunca exponer al cliente)
# SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
